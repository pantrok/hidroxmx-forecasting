# Copy this file to `.env` and fill in the four values. `.env` is gitignored.
# The same credentials used by the sibling repository `hidroxai-mx` work here:
# the forecasting pipeline reads the dataset snapshot from the same R2 bucket
# and writes model artefacts under R2_PAPER2_PREFIX/... on that same bucket.

# --- Cloudflare R2 (S3-compatible) ---
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET=hidroxai-mx
AWS_ACCESS_KEY_ID=<access_key_id>
AWS_SECRET_ACCESS_KEY=<secret_access_key>
AWS_DEFAULT_REGION=auto

# --- Prefixes inside the bucket ---
# Where hidroxai-mx has published the dataset snapshot
R2_DATASET_PREFIX=dvcstore
# Where this repository writes checkpoints and artefacts
R2_PAPER2_PREFIX=paper2

# --- Optional: local Colab cache dir (defaults to /content/cache) ---
LOCAL_CACHE_DIR=/content/cache
